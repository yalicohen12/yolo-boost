# ============================================================================
# YOLO Boost Configuration
# ============================================================================
# Rename this file: mv .env.yolo-boost.example .env.yolo-boost
# CLI flags always override these values.
# ============================================================================

# ── MLflow ───────────────────────────────────────────────────────────────────
# Where to store experiment results. Defaults to ./mlruns (local, no server).
# For a remote server: http://your-mlflow-host:5000
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=yolo-optuna-boost

# ── Data & Device ────────────────────────────────────────────────────────────
DATA_YAML=data.yaml
# cpu,0 , 1, 2 ... (GPU index), or cuda:0
DEVICE=cpu

# ── Training ─────────────────────────────────────────────────────────────────
# Fixed per run — not searched by Optuna (use presets or CLI flags to override)
N_TRIALS=20
EPOCHS=50
PATIENCE=50

# ── Optimization target ──────────────────────────────────────────────────────
# mAP50-95 | mAP50 | precision | recall | speed | balanced
OPTIMIZATION_METRIC=mAP50-95

# ── Models to search ─────────────────────────────────────────────────────────
MODEL_VERSIONS=yolo11n.pt,yolo11s.pt,yolo11m.pt,yolo11l.pt

# ── Optimizers to search (categorical) ───────────────────────────────────────
OPTIMIZER_OPTIONS=SGD,Adam,AdamW,NAdam

# ── Focused search (optional) ────────────────────────────────────────────────
# Comma-separated list of params Optuna will search. Leave empty = search all.
# Fewer params → better TPE convergence per trial.
# Example: model_version,optimizer,batch,lr0,lrf,momentum,weight_decay,box,cls,mosaic
SEARCH_PARAMS=

# ── Batch sizes to search (categorical) ──────────────────────────────────────
BATCH_OPTIONS=8,16,32,64

# ── Learning rate ranges (min,max) ───────────────────────────────────────────
LR0_RANGE=1e-5,1e-1
LRF_RANGE=0.01,1.0
MOMENTUM_RANGE=0.8,0.99
WEIGHT_DECAY_RANGE=0.0,0.01

# ── Warmup ranges ────────────────────────────────────────────────────────────
WARMUP_EPOCHS_RANGE=0,5
WARMUP_MOMENTUM_RANGE=0.0,0.95
WARMUP_BIAS_LR_RANGE=0.0,0.2

# ── Loss weight ranges ───────────────────────────────────────────────────────
# YOLO11/12 defaults: box=7.5, cls=0.5, dfl=1.5
BOX_RANGE=1.0,20.0
CLS_RANGE=0.1,4.0
DFL_RANGE=0.5,4.0

# ── Regularization ───────────────────────────────────────────────────────────
LABEL_SMOOTHING_RANGE=0.0,0.1

# ── Color augmentation ranges ────────────────────────────────────────────────
HSV_H_RANGE=0.0,0.1
HSV_S_RANGE=0.0,0.9
HSV_V_RANGE=0.0,0.9
BGR_RANGE=0.0,1.0

# ── Geometric augmentation ranges ────────────────────────────────────────────
DEGREES_RANGE=0.0,45.0
TRANSLATE_RANGE=0.0,0.5
SCALE_RANGE=0.0,0.9
SHEAR_RANGE=0.0,10.0
PERSPECTIVE_RANGE=0.0,0.001
FLIPUD_RANGE=0.0,1.0
FLIPLR_RANGE=0.0,1.0

# ── Advanced augmentation ranges ─────────────────────────────────────────────
MOSAIC_RANGE=0.0,1.0
MIXUP_RANGE=0.0,1.0
COPY_PASTE_RANGE=0.0,1.0
ERASING_RANGE=0.0,0.9
CLOSE_MOSAIC_RANGE=0,20
