# ============================================================================
# YOLO Optuna Training Configuration
# ============================================================================
# Copy this file to .env and customize for your setup
# ============================================================================

# ============================================================================
# MLflow Configuration
# ============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=yolo-optuna-boost

# ============================================================================
# Optuna Configuration
# ============================================================================
OPTUNA_STUDY_NAME=yolo-optimization
OPTUNA_N_TRIALS=20
# Optional: Use SQLite for persistent storage
# OPTUNA_STORAGE=sqlite:///optuna_study.db
OPTUNA_STORAGE=

# ============================================================================
# Data Configuration
# ============================================================================
DATA_YAML=data.yaml

# ============================================================================
# Device Configuration
# ============================================================================
# Device to use for training (cpu, 0, 1, 2, etc. for GPU)
DEVICE=cpu

# ============================================================================
# Optimization Target
# ============================================================================
# Metric to optimize: mAP50, mAP50-95, precision, recall, speed, balanced
# - mAP50-95: Best overall accuracy (default)
# - mAP50: Faster convergence, good for quick experiments
# - speed: Optimize for inference speed (prioritizes smaller models)
# - balanced: Balance between accuracy (mAP50-95) and speed
OPTIMIZATION_METRIC=mAP50-95

# ============================================================================
# Model Versions to Optimize (comma-separated)
# ============================================================================
# Available: yolo11n.pt, yolo11s.pt, yolo11m.pt, yolo11l.pt, yolo11x.pt
MODEL_VERSIONS=yolo11n.pt,yolo11s.pt,yolo11m.pt,yolo11l.pt

# ============================================================================
# Hyperparameter Search Ranges (min,max)
# Based on official Ultralytics documentation
# ============================================================================

# Learning Rate & Optimization
LR0_RANGE=1e-5,1e-1
LRF_RANGE=0.01,1.0
MOMENTUM_RANGE=0.6,0.98
WEIGHT_DECAY_RANGE=0.0,0.001
WARMUP_EPOCHS_RANGE=0,5
WARMUP_MOMENTUM_RANGE=0.0,0.95

# Loss Weights
BOX_RANGE=0.02,0.2
CLS_RANGE=0.2,4.0
DFL_RANGE=0.4,2.0

# Image & Batch Sizes (comma-separated options)
# IMGSZ_OPTIONS=320,416,512,640
BATCH_OPTIONS=8,16,32,64

# Training Epochs
EPOCHS_RANGE=10,10

# Color Augmentation (HSV)
HSV_H_RANGE=0.0,0.1
HSV_S_RANGE=0.0,0.9
HSV_V_RANGE=0.0,0.9

# Geometric Augmentation
DEGREES_RANGE=0.0,45.0
TRANSLATE_RANGE=0.0,0.9
SCALE_RANGE=0.0,0.9
SHEAR_RANGE=0.0,10.0
PERSPECTIVE_RANGE=0.0,0.001

# Flip Augmentation
FLIPUD_RANGE=0.0,1.0
FLIPLR_RANGE=0.0,1.0

# Advanced Augmentation
MOSAIC_RANGE=0.0,1.0
MIXUP_RANGE=0.0,1.0
COPY_PASTE_RANGE=0.0,1.0
